# Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=your_api_key_here

# 모델 설정 (비용 최적화)
# 오케스트레이터/플래너: 빠르고 저렴한 Haiku
ORCHESTRATOR_MODEL=claude-haiku-4-5-20251001
PLANNER_MODEL=claude-haiku-4-5-20251001
# 개발: 품질 좋은 Sonnet
DEV_MODEL=claude-sonnet-4-6

# Gmail 설정 (뉴스 이메일 발송용)
# 앱 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_RECIPIENT=sunghyo.byoun@gmail.com

# 작업 저장 파일 경로 (변경 불필요)
TASKS_FILE=data/tasks.json
SCHEDULE_FILE=data/schedule.json
MEMORY_FILE=memory/context.json

# Phase 5 - Notion 연동
# 설정 방법: https://www.notion.so/my-integrations → 새 통합 만들기
NOTION_API_KEY=secret_xxxxxxxxxxxx
NOTION_TASKS_DB_ID=your_notion_tasks_database_id
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id

# Phase 5 - Google Calendar
# credentials.json 파일을 Agent J 폴더에 저장 후 setup_google_auth.py 실행
# (GOOGLE_* 환경변수 불필요 — credentials.json + data/google_token.json 파일로 관리)
